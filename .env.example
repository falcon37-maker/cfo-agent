# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Shopify Admin API tokens, one per store ─────────────────────────────────
# Format for each store: <SHORT_CODE>_DOMAIN + <SHORT_CODE>_TOKEN
# SHORT_CODE must match the `id` column in the `stores` table (uppercase).
# Token is a Custom App Admin API access token, starts with shpat_
#
# NOVA (primary store we're testing against)
NOVA_DOMAIN=
NOVA_TOKEN=

# Add more stores as needed:
# KOVA_DOMAIN=
# KOVA_TOKEN=
# NURA_DOMAIN=
# NURA_TOKEN=

# Shopify Admin API version (pinned)
SHOPIFY_API_VERSION=2025-01

# No shared password anymore — /cogs and /ads use Supabase Auth.
# Create users in Supabase Dashboard → Authentication → Users.

# Vercel cron secret — required for /api/cron/* endpoints to accept requests.
# Vercel auto-injects `Authorization: Bearer $CRON_SECRET` on scheduled runs.
CRON_SECRET=
